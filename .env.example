PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hospital_chatbot

# Meta WhatsApp Cloud API webhook verification (Meta App Dashboard -> Webhooks)
META_WEBHOOK_VERIFY_TOKEN=change_me
META_GRAPH_API_VERSION=v20.0
# App Secret (Meta App Dashboard -> Settings -> Basic -> App Secret). Used to
# verify the X-Hub-Signature-256 header on incoming webhook POSTs so forged
# messages can't be sent to your bot. Leave unset only for local dev without
# a public webhook URL — verification is skipped (with a startup warning)
# when this is blank, never silently unsafe in a way you can't see logged.
META_APP_SECRET=change_me

# Simple static key for admin automation endpoints (payment confirmation etc.)
ADMIN_API_KEY=change_me

# Admin panel login (JWT). Generate a real random value for production.
JWT_SECRET=change_me
JWT_EXPIRES_IN=8h
